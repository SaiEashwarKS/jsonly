{
  "name": "@jsonly/extension-ui",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./index.css": "./src/index.css"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --type-aware .",
    "format": "oxfmt --write --no-error-on-unmatched-pattern .",
    "format:check": "oxfmt --check --no-error-on-unmatched-pattern ."
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "jsdom": "^26",
    "vite": "^8",
    "vitest": "^4"
  }
}
