{
  "name": "jsonly",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "package": "pnpm build && pnpm package:chrome && pnpm package:firefox",
    "package:chrome": "cd apps/chrome/dist && zip -r ../../../chrome.zip . -x '*.DS_Store'",
    "package:firefox": "cd apps/firefox/dist && zip -r ../../../firefox.zip . -x '*.DS_Store'"
  },
  "devDependencies": {
    "oxfmt": "^0.43",
    "oxlint": "^1",
    "oxlint-tsgolint": "^0.19.0",
    "turbo": "^2",
    "typescript": "^6"
  }
}
